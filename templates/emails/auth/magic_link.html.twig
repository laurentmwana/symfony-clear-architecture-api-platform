{% extends "layouts/email.html.twig" %}

{% block title %}
Magic Link
{% endblock %}

{% block body %}
     <h2>Hello 👋</h2>

    <p>
        You requested a secure login link.
    </p>

    <p>
        Click the button below to sign in:
    </p>

    <p style="margin: 24px 0;">
        <a
            href="{{magicLinkUrl}}"
            style="
                display: inline-block;
                padding: 12px 20px;
                background-color: #111;
                color: #fff;
                text-decoration: none;
                border-radius: 6px;
            "
        >
            Sign in securely
        </a>
    </p>

    <p>
        Or copy and paste this link in your browser: {{magicLinkUrl}}
    </p>

    <p style="word-break: break-all;">

    </p>

    <hr>

    <p style="font-size: 12px; color: #666;">
        This link will expire in <strong>{{ expiresAt.format('Y-m-d H:i') }}</strong>.<br>
        If you did not request this login, you can ignore this email.
    </p>
{% endblock %}
