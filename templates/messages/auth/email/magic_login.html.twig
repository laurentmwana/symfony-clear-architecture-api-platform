{% extends "layouts/email.html.twig" %}

{% block title %}
   Your Magic Login Code
{% endblock %}

{% block body %}
   <h2>Hello {{ username|default('') }} 👋</h2>

   <p>
      You requested a secure login. Use the code below to sign in:
   </p>

   <p style="font-size: 36px; font-weight: bold; margin: 30px 0; padding: 20px; background-color: #f0f0f0; text-align: center; letter-spacing: 4px; border-radius: 8px;">
      {{ code }}
   </p>

   <p>
      This code is valid for <strong>{{ expiresMinutes|default(10) }} minutes</strong>.
   </p>

   <hr style="margin: 30px 0;">

   <p style="font-size: 12px; color: #666;">
      If you did not request this login, please ignore this email.
   </p>
{% endblock %}
